{
  "name": "wiki",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Astro-powered static site for Matt's wiki",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "astro sync",
    "build": "astro build && npm run build:search",
    "build:search": "pagefind --site dist --glob \"**/*.html\"",
    "preview": "astro preview",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "check": "astro check",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/sitemap": "^3.7.1",
    "@biomejs/biome": "^2.4.10",
    "@iconify-json/lucide": "^1.2.44",
    "@types/node": "^24.6.0",
    "astro": "^5.18.1",
    "astro-icon": "^1.1.5",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.3.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.80.0"
  }
}
