---
import SidebarTree from "@components/SidebarTree.astro";
import type { WikiNode } from "@lib/wiki";

type Props = {
  nodes: WikiNode[];
  currentRoute: string;
  activeParents: Set<string>;
};

const { nodes, currentRoute, activeParents } = Astro.props;
---

<aside id="sidebar-panel" class="sidebar" data-pagefind-ignore>
  <div id="sidebar-inner" class="sidebar-inner">
    <SidebarTree nodes={nodes} currentRoute={currentRoute} activeParents={activeParents} />
  </div>
</aside>

<style>
  .sidebar {
    grid-column: 1 / 2;
    grid-row: 2 / 4;
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
    border-right: 1px solid var(--border);
    background: var(--surface);
  }

  .sidebar-inner {
    min-height: 0;
    padding: 0.9rem;
    overflow: auto;
  }

  @media (max-width: 960px) {
    .sidebar {
      display: none;
      position: fixed;
      top: var(--mobile-header-height, 4.2rem);
      bottom: 0;
      left: 0;
      z-index: 40;
      width: 100%;
      max-width: 100%;
      border-right: 0;
      border-top: 1px solid var(--border);
      border-bottom: 0;
      box-shadow: none;
    }

    :global([data-sidebar-open="true"]) .sidebar {
      display: flex;
    }
  }
</style>
