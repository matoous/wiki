---
const { label, title = label, class: className, type = "button", ...attrs } = Astro.props;
---

<button
  type={type}
  class:list={["icon-button", className]}
  aria-label={label}
  title={title}
  {...attrs}
>
  <slot />
</button>

<style>
  .icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    padding: 0;
    appearance: none;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .icon-button:hover,
  .icon-button:focus-visible {
    color: var(--text);
    background: var(--surface-muted);
  }

  .icon-button:focus-visible {
    outline: 1px solid var(--border-strong);
    outline-offset: 2px;
  }

  .icon-button:active {
    transform: scale(0.96);
  }

  .icon-button :global(svg) {
    display: block;
    width: 18px;
    height: 18px;
  }
</style>
