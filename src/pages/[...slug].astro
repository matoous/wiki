---
import { render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAllPages, getPageByRoute } from "@lib/wiki";

export async function getStaticPaths() {
  const pages = (await getAllPages()).filter((page) => page.route !== "/");

  return pages.map((page) => ({
    params: {
      slug: page.route === "/" ? undefined : page.route.split("/").filter(Boolean).join("/"),
    },
    props: {
      route: page.route,
    },
  }));
}

const route =
  Astro.props.route ?? (Astro.params.slug ? `/${Astro.params.slug}/` : "/");
const page = await getPageByRoute(route);

if (!page) {
  throw new Error(`Missing wiki page for route: ${route}`);
}

const { Content } = await render(page.entry);
---

<BaseLayout page={page}>
  <article data-pagefind-body>
    <Content />
  </article>
</BaseLayout>
